Node: dcs:Count_MarriageEvent
typeOf: dcs:StatisticalVariable
populationType: dcs:MarriageEvent
measuredProperty: dcs:count
statType: dcs:measuredValue
name: "Count of Marriage Events"
description: "The total number of registered marriage events in a given place and period."

Node: dcs:Count_MarriageEvent_AsAFractionOf_Count_Person
typeOf: dcs:StatisticalVariable
populationType: dcs:MarriageEvent
measuredProperty: dcs:count
statType: dcs:measuredValue
measurementDenominator: dcs:Count_Person
name: "Crude Marriage Rate"
description: "The ratio of the total number of registered marriage events to the total population, representing the crude marriage rate (expressed per person, scaled to per 1,000 residents in tables)."

Node: dcs:Count_MarriageEvent_Female_NeverMarried_AsAFractionOf_Count_MarriageEvent_Female
typeOf: dcs:StatisticalVariable
populationType: dcs:MarriageEvent
measuredProperty: dcs:count
statType: dcs:measuredValue
measurementDenominator: dcs:Count_MarriageEvent_Female
gender: dcs:Female
maritalStatus: dcs:NeverMarried
name: "Proportion of First Marriages: Female"
description: "The proportion of total female marriage events where the bride's prior marital status was never married, indicating the fraction of first marriages among all registered female marriages."

