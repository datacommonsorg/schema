#
# Population of armed forces
#
# Note: There is some concern with including
# employmentStatus=BLS_InLaborForce It is a DPV of armedForcesStatus as
# InArmedForces, but not for Civilian.  If we add as DPV, then it might mess
# up how Civilian stats show. If we don't add as DPV, then the total won't
# show up below "In Armed Forces" (which is what will happen).
#
Node: dcid:Count_Person_InArmedForces
typeOf: dcs:StatisticalVariable
populationType: dcs:Person
measuredProperty: dcs:count
statType: dcs:measuredValue
age: dcs:Years16Onwards
armedForcesStatus: dcs:InArmedForces
employmentStatus: dcs:BLS_InLaborForce

Node: dcid:Count_Person_Female_InArmedForces
typeOf: dcs:StatisticalVariable
populationType: dcs:Person
measuredProperty: dcs:count
statType: dcs:measuredValue
age: dcs:Years16Onwards
armedForcesStatus: dcs:InArmedForces
gender: schema:Female
employmentStatus: dcs:BLS_InLaborForce

Node: dcid:Count_Person_Male_InArmedForces
typeOf: dcs:StatisticalVariable
populationType: dcs:Person
measuredProperty: dcs:count
statType: dcs:measuredValue
age: dcs:Years16Onwards
armedForcesStatus: dcs:InArmedForces
gender: schema:Male
employmentStatus: dcs:BLS_InLaborForce

